<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  OTA-манифест Ad Hoc установки Tempora (iOS).
  Это ШАБЛОН: плейсхолдеры (URL IPA, версия, базовый URL папки)
  подставляются при сборке (см. .github/workflows/ios.yml, режим adhoc,
  и scripts/gen_ios_manifest.py).

  Apple требует, чтобы И этот .plist, И сам .ipa, И иконки отдавались по
  HTTPS с валидным сертификатом, иначе Safari молча не запустит установку.
  Ссылка вида itms-services://?action=download-manifest&url=<HTTPS-URL-этого-plist>
  открывает диалог «Установить Tempora».
-->
<plist version="1.0">
<dict>
  <key>items</key>
  <array>
    <dict>
      <key>assets</key>
      <array>
        <dict>
          <key>kind</key><string>software-package</string>
          <key>url</key><string>https://plan.akoev.com/ios/Tempora-b67.ipa</string>
        </dict>
        <dict>
          <key>kind</key><string>display-image</string>
          <key>url</key><string>https://plan.akoev.com/ios/icon-display.png</string>
        </dict>
        <dict>
          <key>kind</key><string>full-size-image</string>
          <key>url</key><string>https://plan.akoev.com/ios/icon-full.png</string>
        </dict>
      </array>
      <key>metadata</key>
      <dict>
        <key>bundle-identifier</key><string>ru.akoti.plan</string>
        <key>bundle-version</key><string>0.1.9</string>
        <key>kind</key><string>software</string>
        <key>title</key><string>Tempora</string>
      </dict>
    </dict>
  </array>
</dict>
</plist>
